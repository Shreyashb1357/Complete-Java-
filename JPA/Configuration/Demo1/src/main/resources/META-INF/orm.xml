<entity-mappings xmlns="https://jakarta.ee/xml/ns/persistence/orm"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	version="3.1">

	<entity class="app.Tourism.Data.TravellerEntity">        
		<table name="Traveller"/>
		<attributes>
			<id name="id">
				<column name="traveller_id"/>
			</id>
			<basic name="rating">
				<column name="rating"/>
			</basic>
			<one-to-many name="tours" mapped-by="guest">
				<cascade>
					<cascade-all/>
				</cascade>
			</one-to-many>
		</attributes>
	</entity>

	<entity class="app.Tourism.Data.TripsEntity">        
		<table name="Trips"/>
		<attributes>
			<id name="id">
				<column name=""/>
				<generated-value strategy="IDENTITY"/>
			</id>
			<basic name="checkin">
				<column name="checkiin_date"/>
			</basic>
			<many-to-one name="guest">
				<join-column name="traveler_id"/>
			</many-to-one>
		</attributes>
	</entity>

</entity-mappings>

